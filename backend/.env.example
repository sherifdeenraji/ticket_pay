# Server Config
PORT=5000
NODE_ENV=development

# Database Config
DB_USER=your_user
DB_PASSWORD=your_password
DB_HOST=localhost
DB_PORT=5432
DB_NAME=ticketpay

# JWT Secrets
JWT_SECRET=your_user_jwt_secret_change_me
ADMIN_JWT_SECRET=your_admin_jwt_secret_change_me
JWT_EXPIRES_IN=1d

# Admin Credentials (Initial Seed)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change_this_password_in_env

# Google OAuth
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_CALLBACK_URL=http://localhost:5000/api/auth/google/callback

# Mailtrap Config
MAIL_HOST=sandbox.smtp.mailtrap.io
MAIL_PORT=2525
MAIL_USER=your_mailtrap_user
MAIL_PASS=your_mailtrap_password
MAIL_FROM=no-reply@ticketpay.oau.edu

# Nomba Config
NOMBA_CLIENT_ID=your_nomba_client_id
NOMBA_CLIENT_SECRET=your_nomba_client_secret
NOMBA_ACCOUNT_ID=your_nomba_account_id
NOMBA_WEBHOOK_SECRET=your_nomba_webhook_secret
NOMBA_BASE_URL=https://api.nomba.com

# Frontend URLs
STUDENT_FRONTEND_URL=http://localhost:3000
ADMIN_FRONTEND_URL=http://localhost:3001
